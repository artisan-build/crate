{
    "name": "artisan-build/crate-client",
    "description": "The client package for Crate private Composer registry integrations.",
    "keywords": ["crate", "composer", "laravel", "client", "registry"],
    "license": "MIT",
    "type": "library",
    "version": "1.0.0",
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "laravel/pint": "^1.27"
    },
    "autoload": {
        "psr-4": {
            "ArtisanBuild\\CrateClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ArtisanBuild\\CrateClient\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "lint": "pint",
        "lint:test": "pint --test"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
